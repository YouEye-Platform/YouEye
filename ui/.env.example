# YouEye-UI Environment Variables
# Copy to .env.local for local development

# External URL (how users reach this app, including protocol)
UI_EXTERNAL_URL=https://skibidi.wtf

# Authentik OAuth2 (from Authentik provider configuration)
AUTHENTIK_URL=https://auth.skibidi.wtf
AUTHENTIK_INTERNAL_URL=http://10.x.x.x:9000
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=

# JWT secret for session tokens (at least 32 characters)
JWT_SECRET=

# PostgreSQL connection string
DATABASE_URL=postgresql://yeui:PASSWORD@10.x.x.x:5432/yeui

# Set to "false" to disable Secure flag on cookies (for HTTP dev)
SECURE_COOKIES=true
